    "deploy:goerli": "hardhat run scripts/deploy.js --network goerli",
    "verify": "hardhat verify --network sepolia",
    "clean": "hardhat clean",
    "node": "hardhat node"
  },
  "keywords": [
    "origin-os",
    "memory",
    "bridge",
    "wormhole",
    "solana",
    "ethereum",
