{
  "name": "@origin-os/memory-bridge-ethereum",
  "version": "0.1.0",
  "description": "Ethereum bridge for Origin OS Memory Registry - Wormhole cross-chain integration",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
